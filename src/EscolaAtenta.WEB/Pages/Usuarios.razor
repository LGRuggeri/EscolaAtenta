@page "/usuarios"
@attribute [Authorize(Roles = "Administrador")]
@inject ApiService Api
@inject IToastService Toast
@inject NavigationManager Nav
@using System.ComponentModel.DataAnnotations

<PageTitle>Gestão de Usuários - EscolaAtenta</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4 mt-2">
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="Voltar" title="Voltar ao Início">
            ← Voltar
        </button>
        <div>
            <h1 class="h3 mb-1" style="color: var(--cor-primaria); font-weight: var(--peso-negrito);">Gestão de Usuários</h1>
            <p class="text-secondary mb-0">Crie novos acessos controlados ao sistema.</p>
        </div>
    </div>
    <button class="btn btn-primary" style="background-color: var(--cor-verde); border-color: var(--cor-verde-escuro);" @onclick="AbrirFormulario">
        ➕ Novo Usuário
    </button>
</div>

@if (isModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(16, 25, 51, 0.4); backdrop-filter: blur(2px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: var(--raio-borda);">
                <div class="modal-header" style="background-color: var(--cor-primaria-fundo); border-radius: var(--raio-borda) var(--raio-borda) 0 0;">
                    <h5 class="modal-title fw-bold" style="color: var(--cor-primaria);">👤 Novo Usuário</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                
                @if (senhaGerada != null)
                {
                    <div class="modal-body p-4 text-center">
                        <div class="alert alert-success mt-2 mb-4" role="alert" style="background-color: var(--cor-verde-claro); border-color: var(--cor-verde);">
                            <h4 class="alert-heading fw-bold mb-3">Usuário Criado com Sucesso!</h4>
                            <p class="mb-2">Por questões de segurança, a senha provisória só é exibida agora. Copie e envie para o colaborador associado ao e-mail <strong>@novoUsuario.Email</strong>:</p>
                            <hr>
                            <div class="bg-white p-3 rounded border my-3">
                                <span class="fs-4 text-break" style="font-family: monospace; font-weight: bold; letter-spacing: 2px;">@senhaGerada</span>
                            </div>
                            <p class="mb-0 small text-danger fw-bold"><i class="bi bi-exclamation-triangle"></i> IMPORTANTE: Anote esta senha! Ela não poderá ser recuperada posteriormente.</p>
                        </div>
                        <button type="button" class="btn btn-primary px-5" @onclick="CloseModalEConcluir" style="background-color: var(--cor-primaria); border-color: var(--cor-primaria);">
                            Entendido, fechar
                        </button>
                    </div>
                }
                else
                {
                    <EditForm Model="@novoUsuario" OnValidSubmit="SalvarUsuario" class="modal-body p-4">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger mb-3 p-2" />

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Nome Completo</label>
                            <InputText @bind-Value="novoUsuario.Nome" class="form-control" placeholder="Ex: Ana Silva" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">E-mail Corporativo</label>
                            <InputText @bind-Value="novoUsuario.Email" type="email" class="form-control" placeholder="Ex: ana.silva@escola.br" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Papel (Permissão)</label>
                            <InputSelect @bind-Value="novoUsuario.Papel" class="form-select">
                                <option value="0">Selecione uma permissão...</option>
                                <option value="1">Monitor (Acesso à Chamada e Alunos)</option>
                                <option value="2">Supervisão (Apenas Leitura de Painéis)</option>
                                <option value="3">Administrador (Acesso Total)</option>
                            </InputSelect>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <button type="button" class="btn btn-secondary px-4" @onclick="CloseModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary px-4" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Salvando...</span>
                                }
                                else
                                {
                                    <span>Cadastrar Usuário</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
            </div>
        </div>
    </div>
}

<div class="card border-0 shadow-sm mt-3" style="border-radius: var(--raio-borda); background-color: var(--cor-primaria-fundo);">
    <div class="card-body p-5 text-center">
        <h3 class="fw-bold mb-3" style="color: var(--cor-primaria);">Painel Operacional Restrito</h3>
        <p class="text-secondary mb-4 mx-auto" style="max-width: 600px;">
            Apenas usuários autenticados com o papel de <strong>Administrador</strong> têm acesso a este painel administrativo. Você pode provisionar novos perfis que terão acessos granulares baseados na sua carga (Monitores podem realizar marcações, Supervisores apenas visualizam dashboards).
        </p>
        <button class="btn btn-outline-primary mt-2" @onclick="AbrirFormulario">
            <span class="me-2">🛡️</span> Iniciar Cadastro de Funcionario
        </button>
    </div>
</div>

@code {
    private void Voltar() => Nav.NavigateTo("/");

    private bool isSaving = false;
    private bool isModalOpen = false;
    private string? senhaGerada = null;
    
    private NovoUsuarioModel novoUsuario = new();

    private void AbrirFormulario()
    {
        novoUsuario = new();
        senhaGerada = null;
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        senhaGerada = null;
        novoUsuario = new();
    }

    private void CloseModalEConcluir()
    {
        isModalOpen = false;
        senhaGerada = null;
        novoUsuario = new();
    }

    private async Task SalvarUsuario()
    {
        // Validacao customizada de select
        if (novoUsuario.Papel == 0)
        {
            Toast.ShowError("É obrigatório selecionar uma permissão (Papel) para o novo usuário.");
            return;
        }

        isSaving = true;
        try
        {
            var request = new CriarUsuarioRequest(
                novoUsuario.Nome, 
                novoUsuario.Email, 
                (PapelUsuarioDto)novoUsuario.Papel
            );
            
            var result = await Api.CriarUsuarioAsync(request);
            
            if (result != null)
            {
                // Deixa o modal aberto, mas muda a view interna para exibir a senha:
                senhaGerada = result.SenhaInicial;
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private class NovoUsuarioModel
    {
        [Required(ErrorMessage = "O Nome Completo é obrigatório.")]
        [StringLength(150, ErrorMessage = "O nome não pode exceder 150 caracteres.")]
        public string Nome { get; set; } = "";

        [Required(ErrorMessage = "O E-mail Corporativo é obrigatório.")]
        [EmailAddress(ErrorMessage = "Formato de e-mail inválido.")]
        public string Email { get; set; } = "";

        // Uso INT para forcar a selecao no Select.
        public int Papel { get; set; } = 0; 
    }
}
