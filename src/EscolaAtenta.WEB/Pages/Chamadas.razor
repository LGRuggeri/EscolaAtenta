@page "/chamadas"
@attribute [Authorize]
@inject ApiService Api
@inject IToastService Toast
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Chamadas - EscolaAtenta</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4 mt-2">
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="Voltar" title="Voltar ao Início">
            ← Voltar
        </button>
        <div>
            <h1 class="h3 mb-1" style="color: var(--cor-primaria); font-weight: var(--peso-negrito);">Lançamento de Chamada</h1>
            <p class="text-secondary mb-0">Registre a presença ou falta de toda a turma de uma só vez.</p>
        </div>
    </div>
</div>

@if (isLoadingTurmas)
{
    <div class="text-center my-3">
        <div class="spinner-border spinner-border-sm" style="color: var(--cor-primaria);" role="status"></div>
        <span class="ms-2">Carregando turmas...</span>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4" style="border-radius: var(--raio-borda);">
        <div class="card-body">
            <label class="form-label fw-bold" style="color: var(--cor-primaria);">1. Selecione a Turma/Série:</label>
            <select class="form-select form-select-lg" @onchange="OnTurmaChanged">
                <option value="">-- Escolha uma Turma para abrir a pauta --</option>
                @foreach (var turma in turmas)
                {
                    <option value="@turma.Id">@turma.Nome (@turma.Turno)</option>
                }
            </select>
        </div>
    </div>
}

@if (turmaSelecionadaId != null)
{
    @if (isLoadingAlunos)
    {
        <div class="text-center my-5">
            <div class="spinner-border" style="color: var(--cor-primaria);" role="status">
                <span class="visually-hidden">Carregando Diário de Classe...</span>
            </div>
            <p class="mt-2 text-secondary">Abrindo pauta da turma...</p>
        </div>
    }
    else if (!alunos.Any())
    {
        <div class="alert alert-warning" style="background-color: var(--cor-aviso-fundo); border-color: var(--cor-aviso);">
            Esta turma ainda não possui nenhum aluno matriculado. Não é possível fazer a chamada.
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm mb-4" style="border-radius: var(--raio-borda);">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2">
                <h5 class="mb-0 fw-bold" style="color: var(--cor-primaria);">2. Diário de Classe</h5>
                <p class="text-muted small">Por padrão, todos os alunos estão marcados como <strong>Presente</strong>. Altere apenas quem faltou.</p>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: var(--cor-primaria-fundo);">
                        <tr>
                            <th class="ps-4" style="width: 40%;">Aluno</th>
                            <th style="width: 60%; text-align: center;">Status de Presença</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var aluno in alunos)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold" style="color: var(--cor-primaria);">@aluno.Nome</div>
                                </td>
                                <td>
                                    <div class="btn-group w-100 shadow-sm" role="group">
                                        <input type="radio" class="btn-check" name="status-@aluno.Id" id="presente-@aluno.Id" autocomplete="off" 
                                               checked="@(GetStatus(aluno.Id) == StatusPresenca.Presente)" 
                                               @onchange="() => SetStatus(aluno.Id, StatusPresenca.Presente)">
                                        <label class="btn btn-outline-success px-4" for="presente-@aluno.Id">Presente</label>

                                        <input type="radio" class="btn-check" name="status-@aluno.Id" id="falta-@aluno.Id" autocomplete="off" 
                                               checked="@(GetStatus(aluno.Id) == StatusPresenca.Falta)" 
                                               @onchange="() => SetStatus(aluno.Id, StatusPresenca.Falta)">
                                        <label class="btn btn-outline-danger px-4" for="falta-@aluno.Id">Falta</label>
                                        
                                        <input type="radio" class="btn-check" name="status-@aluno.Id" id="justificada-@aluno.Id" autocomplete="off" 
                                               checked="@(GetStatus(aluno.Id) == StatusPresenca.FaltaJustificada)" 
                                               @onchange="() => SetStatus(aluno.Id, StatusPresenca.FaltaJustificada)">
                                        <label class="btn btn-outline-warning px-4" for="justificada-@aluno.Id" style="color: #856404;">Justificada</label>

                                        <input type="radio" class="btn-check" name="status-@aluno.Id" id="ausente-@aluno.Id" autocomplete="off" 
                                               checked="@(GetStatus(aluno.Id) == StatusPresenca.Ausente)" 
                                               @onchange="() => SetStatus(aluno.Id, StatusPresenca.Ausente)">
                                        <label class="btn btn-outline-secondary px-4" for="ausente-@aluno.Id">Ausente</label>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-white border-top p-4 d-flex justify-content-end">
                <button class="btn btn-primary btn-lg" style="background-color: var(--cor-verde); border-color: var(--cor-verde-escuro); padding-left: 3rem; padding-right: 3rem;" @onclick="EnviarChamada" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Confirmando na API...</span>
                    }
                    else
                    {
                        <span class="fw-bold">✅ Salvar Diário de Classe</span>
                    }
                </button>
            </div>
        </div>
    }
}

@code {
    private void Voltar() => Nav.NavigateTo("/");

    private bool isLoadingTurmas = true;
    private bool isLoadingAlunos = false;
    private bool isSubmitting = false;
    
    private List<TurmaDto> turmas = new();
    private List<AlunoDto> alunos = new();
    private Guid? turmaSelecionadaId;
    
    // Dicionário para rastrear os status localmente
    private Dictionary<Guid, StatusPresenca> statusPresencas = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarTurmas();
    }

    private async Task CarregarTurmas()
    {
        isLoadingTurmas = true;
        try
        {
            var result = await Api.GetTurmasAsync();
            turmas = result.ToList();
        }
        finally
        {
            isLoadingTurmas = false;
        }
    }

    private async Task OnTurmaChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrEmpty(value))
        {
            turmaSelecionadaId = null;
            alunos.Clear();
            statusPresencas.Clear();
            return;
        }

        if (Guid.TryParse(value, out var turmaId))
        {
            turmaSelecionadaId = turmaId;
            await CarregarAlunos(turmaId);
        }
    }

    private async Task CarregarAlunos(Guid turmaId)
    {
        isLoadingAlunos = true;
        try
        {
            var result = await Api.GetAlunosPorTurmaAsync(turmaId);
            alunos = result.ToList();
            
            // Inicializar todos com "Presente" por padrao para agilizar
            statusPresencas.Clear();
            foreach (var aluno in alunos)
            {
                statusPresencas[aluno.Id] = StatusPresenca.Presente;
            }
        }
        finally
        {
            isLoadingAlunos = false;
        }
    }

    private StatusPresenca GetStatus(Guid alunoId)
    {
        return statusPresencas.TryGetValue(alunoId, out var status) ? status : StatusPresenca.Presente;
    }

    private void SetStatus(Guid alunoId, StatusPresenca novoStatus)
    {
        statusPresencas[alunoId] = novoStatus;
    }

    private async Task EnviarChamada()
    {
        if (turmaSelecionadaId == null || !alunos.Any()) return;

        isSubmitting = true;
        try
        {
            // Opcional: pegar Id do professor logado (Guid Fake para MVP ou ID do Claim)
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userIdString = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            
            Guid responsavelId = Guid.NewGuid(); // Fallback
            if (Guid.TryParse(userIdString, out var parsedId))
            {
                responsavelId = parsedId;
            }

            // Montar Lista de Registros
            var registros = statusPresencas
                .Select(kvp => new RegistroAlunoDto(kvp.Key, kvp.Value))
                .ToList();

            var request = new RealizarChamadaRequest(turmaSelecionadaId.Value, responsavelId, registros);
            
            var result = await Api.RealizarChamadaAsync(request);
            
            if (result != null)
            {
                if (result.AlertasGerados > 0)
                {
                    Toast.ShowWarning($"Chamada salva! {result.AlertasGerados} alerta(s) de evasão foram acionados para a supervisão.");
                }
                
                // Limpar tela para não ter double submission ou rearmar do zero
                turmaSelecionadaId = null;
                alunos.Clear();
                statusPresencas.Clear();
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
