@page "/"
@attribute [Authorize]

<PageTitle>EscolaAtenta — Início</PageTitle>

<div class="home-container">
    <div class="welcome-card card p-4 mb-4">
        <div class="d-flex align-items-center gap-3 mb-3">
            <span style="font-size: 2.5rem;">🏫</span>
            <div>
                <h1 class="mb-0">EscolaAtenta</h1>
                <p class="text-muted mb-0">Sistema de Controle de Presença Escolar</p>
            </div>
        </div>
        <hr style="border-color: var(--cor-borda);" />
        <p class="mb-0" style="color: var(--cor-texto-secundario);">
            Bem-vindo ao sistema de gestão de presença. Utilize o menu lateral para
            acessar turmas, alunos, chamadas e alertas de evasão.
        </p>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card p-3 text-center">
                <div class="stat-icon">🏛️</div>
                <div class="stat-label">Turmas</div>
                <a href="turmas" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card p-3 text-center">
                <div class="stat-icon">👨‍🎓</div>
                <div class="stat-label">Alunos</div>
                <a href="alunos" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card p-3 text-center">
                <div class="stat-icon">📋</div>
                <div class="stat-label">Chamadas</div>
                <a href="chamadas" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card p-3 text-center">
                <div class="stat-icon">⚠️</div>
                <div class="stat-label">Alertas de Evasão</div>
                <a href="alertas" class="stretched-link"></a>
            </div>
        </div>
    </div>
</div>

<style>
    .home-container {
        max-width: 900px;
    }

    .welcome-card {
        border-left: 4px solid var(--cor-dourado);
    }

    .stat-card {
        cursor: pointer;
        position: relative;
        transition: var(--transicao);
    }

    .stat-card:hover {
        border-color: var(--cor-dourado);
        transform: translateY(-2px);
    }

    .stat-icon {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }

    .stat-label {
        font-weight: var(--peso-medio);
        color: var(--cor-texto-secundario);
        font-size: 0.9rem;
    }
</style>
