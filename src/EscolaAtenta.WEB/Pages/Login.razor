@page "/login"
@inject NavigationManager Navigation
@inject IToastService ToastService
@inject ApiService ApiService
@inject JwtAuthenticationStateProvider AuthStateProvider

<PageTitle>Login - EscolaAtenta</PageTitle>

<div class="login-page">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <h1>EscolaAtenta</h1>
                <p>Controle de Presença Escolar</p>
            </div>

            <EditForm Model="@_loginModel" OnValidSubmit="@HandleLoginAsync" FormName="LoginForm">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label for="email">E-mail</label>
                    <InputText 
                        id="email" 
                        @bind-Value="_loginModel.Email" 
                        class="form-input"
                        placeholder="seu.email@escola.edu.br"
                        disabled="@_isLoading" />
                    <ValidationMessage For="@(() => _loginModel.Email)" class="validation-message" />
                </div>

                <div class="form-group">
                    <label for="senha">Senha</label>
                    <div class="password-input-wrapper">
                        <InputText 
                            id="senha" 
                            type="@_passwordInputType"
                            @bind-Value="_loginModel.Senha" 
                            class="form-input"
                            placeholder="••••••••"
                            disabled="@_isLoading" />
                        <button type="button" class="btn-toggle-password" @onclick="TogglePasswordVisibility" tabindex="-1" title="@(_showPassword ? "Ocultar senha" : "Ver senha")">
                            @if (_showPassword)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => _loginModel.Senha)" class="validation-message" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="error-message">
                        @_errorMessage
                    </div>
                }

                <button type="submit" class="btn-primary" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Entrando...</span>
                    }
                    else
                    {
                        <span>Entrar</span>
                    }
                </button>
            </EditForm>

            <div class="login-footer">
                <small>Sistema desenvolvido para controle de presença escolar</small>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel _loginModel = new();
    private bool _isLoading;
    private string? _errorMessage;
    private bool _showPassword = false;
    private string _passwordInputType => _showPassword ? "text" : "password";

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private async Task HandleLoginAsync()
    {
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var result = await ApiService.LoginAsync(_loginModel.Email, _loginModel.Senha);

            if (result != null)
            {
                // Salvar token no localStorage e marcar usuario como autenticado
                await AuthStateProvider.MarkUserAsAuthenticated(result.Token);
                
                ToastService.ShowSuccess("Bem-vindo ao EscolaAtenta!");
                
                // Redirecionar para a pagina inicial
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _errorMessage = "E-mail ou senha incorretos.";
                ToastService.ShowError("Falha no login. Verifique suas credenciais.");
            }
        }
        catch (Exception)
        {
            _errorMessage = "Ocorreu um erro ao tentar fazer login.";
            ToastService.ShowError("Erro de conexão. Tente novamente mais tarde.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class LoginModel
    {
        [Required(ErrorMessage = "E-mail é obrigatório")]
        [EmailAddress(ErrorMessage = "E-mail inválido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Senha é obrigatória")]
        [MinLength(6, ErrorMessage = "Senha deve ter pelo menos 6 caracteres")]
        public string Senha { get; set; } = string.Empty;
    }
}
