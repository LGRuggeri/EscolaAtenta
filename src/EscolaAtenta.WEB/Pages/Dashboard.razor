@page "/dashboard"
@attribute [Authorize]
@inject DashboardService DashboardService
@inject IToastService ToastService
@inject NavigationManager Nav

<PageTitle>Dashboard - EscolaAtenta</PageTitle>

<style>
    .card-aviso { background-color: var(--cor-aviso-fundo); border-color: var(--cor-aviso); color: #856404; }
    .card-atencao { background-color: #fff3cd; border-color: #fd7e14; color: #e8590c; }
    .card-critico { background-color: var(--cor-erro-fundo); border-color: var(--cor-erro); color: var(--cor-erro); }
    
    .badge-aviso { background-color: var(--cor-aviso-fundo); color: #856404; border: 1px solid var(--cor-aviso); padding: 0.35em 0.65em; border-radius: 0.25rem; font-weight: 600;}
    .badge-atencao { background-color: #fd7e14; color: white; border: 1px solid #e8590c; padding: 0.35em 0.65em; border-radius: 0.25rem; font-weight: 600;}
    .badge-critico { background-color: var(--cor-erro-fundo); color: var(--cor-erro); border: 1px solid var(--cor-erro); font-weight: bold; padding: 0.35em 0.65em; border-radius: 0.25rem;}
    .badge-normal { background-color: var(--cor-fundo-hover); color: var(--cor-texto-secundario); border: 1px solid var(--cor-borda); padding: 0.35em 0.65em; border-radius: 0.25rem;}

    .row-aviso { background-color: rgba(255, 193, 7, 0.05) !important; }
    .row-atencao { background-color: rgba(253, 126, 20, 0.05) !important; }
    .row-critico { background-color: rgba(220, 53, 69, 0.05) !important; border-left: 4px solid var(--cor-erro); }
    
    .resumo-icon { font-size: 2.5rem; }
    .resumo-numero { font-size: 2rem; font-weight: bold; display: block; line-height: 1; }
    .resumo-label { font-size: 0.9rem; opacity: 0.9; }
</style>

<div class="container-fluid px-0">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-2">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-outline-secondary btn-sm" @onclick="Voltar" title="Voltar ao Início">
                ← Voltar
            </button>
            <div>
                <h1 class="h3 mb-1" style="color: var(--cor-primaria); font-weight: var(--peso-negrito);">Painel de Supervisão</h1>
                <p class="text-secondary mb-0">Monitoramento de Freqüência e Risco de Evasão Escolar (Visualização).</p>
            </div>
        </div>
    </div>

    <!-- Filtro por Turma -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: var(--raio-borda);">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-auto">
                    <label for="turma-select" class="form-label fw-bold mb-0" style="color: var(--cor-primaria);">Visualização:</label>
                </div>
                <div class="col-md-5">
                    <select id="turma-select" class="form-select form-select-lg" @bind="TurmaSelecionadaId" @bind:after="OnTurmaChanged">
                        <option value="@Guid.Empty">Todas as Séries e Turmas (Visão Global)</option>
                        @if (Turmas != null)
                        {
                            @foreach (var turma in Turmas)
                            {
                                <option value="@turma.Id">@turma.Nome (@turma.Turno)</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Cards de Resumo -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border mb-3 h-100 card-aviso shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <div class="resumo-icon me-3">⚠️</div>
                    <div>
                        <span class="resumo-numero">@AlunosComAviso</span>
                        <span class="resumo-label fw-bold">1 Falta Consecutiva (Aviso)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border mb-3 h-100 card-atencao shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <div class="resumo-icon me-3">🚨</div>
                    <div>
                        <span class="resumo-numero">@AlunosComAtencao</span>
                        <span class="resumo-label fw-bold">2 Faltas Consecutivas (Atenção)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border mb-3 h-100 card-critico shadow-sm" style="border-width: 2px !important;">
                <div class="card-body d-flex align-items-center">
                    <div class="resumo-icon me-3">🔴</div>
                    <div>
                        <span class="resumo-numero text-danger">@AlunosCriticos</span>
                        <span class="resumo-label fw-bold text-danger">3+ Faltas (Evasão Crítica)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela de Alunos -->
    <div class="card border-0 shadow-sm" style="border-radius: var(--raio-borda);">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-2 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold" style="color: var(--cor-primaria);">Relatório de Faltosos</h5>
            <span class="badge bg-secondary">Total Listados: @Alunos?.Count()</span>
        </div>

        @if (IsLoading)
        {
            <div class="text-center my-5">
                <div class="spinner-border" style="color: var(--cor-primaria);" role="status">
                    <span class="visually-hidden">Calculando dados...</span>
                </div>
                <p class="mt-2 text-secondary">Atualizando métricas do painel...</p>
            </div>
        }
        else if (Alunos == null || !Alunos.Any())
        {
            <div class="alert alert-success m-4" style="background-color: var(--cor-sucesso-fundo); border-color: var(--cor-verde); color: var(--cor-verde-escuro);">
                <span class="fw-bold">✅ Excelente!</span> Nenhum aluno com faltas consecutivas registrado nesta visão.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: var(--cor-primaria-fundo);">
                        <tr>
                            <th class="ps-4">Aluno Faltoso</th>
                            <th>Turma</th>
                            <th class="text-center">Faltas Consecutivas <br/><small class="text-muted">(Gatilho)</small></th>
                            <th class="text-center">Total Histórico</th>
                            <th class="text-center">Nível de Alerta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var aluno in Alunos)
                        {
                            <tr class="@GetRowClass(aluno.NivelAlerta)">
                                <td class="ps-4 fw-bold" style="color: var(--cor-primaria);">@aluno.Nome</td>
                                <td>@aluno.NomeTurma</td>
                                <td class="text-center fs-5 fw-bold">@aluno.FaltasConsecutivasAtuais</td>
                                <td class="text-center">@aluno.TotalFaltas</td>
                                <td class="text-center">
                                    <span class="@GetBadgeClass(aluno.NivelAlerta)">
                                        @GetStatusText(aluno.NivelAlerta)
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private IReadOnlyList<AlunoComFaltasDto>? Alunos;
    private IReadOnlyList<TurmaDto>? Turmas;
    private Guid TurmaSelecionadaId = Guid.Empty;
    private bool IsLoading = true;

    private void Voltar() => Nav.NavigateTo("/");

    // Contadores para cards de resumo
    private int AlunosComAviso => Alunos?.Count(a => a.NivelAlerta == "Aviso") ?? 0;
    private int AlunosComAtencao => Alunos?.Count(a => a.NivelAlerta == "Atencao") ?? 0;
    private int AlunosCriticos => Alunos?.Count(a => a.NivelAlerta == "Critico") ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadTurmasAsync();
        await LoadAlunosAsync();
    }

    private async Task LoadTurmasAsync()
    {
        try
        {
            Turmas = await DashboardService.GetTurmasAsync();
        }
        catch (Exception)
        {
            ToastService.ShowError("Erro ao carregar turmas.");
        }
    }

    private async Task LoadAlunosAsync()
    {
        IsLoading = true;
        try
        {
            var turmaId = TurmaSelecionadaId == Guid.Empty ? (Guid?)null : TurmaSelecionadaId;
            Alunos = await DashboardService.GetAlunosComFaltasAsync(turmaId);
        }
        catch (Exception)
        {
            ToastService.ShowError("Erro ao carregar dados dos alunos.");
            Alunos = [];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task OnTurmaChanged()
    {
        await LoadAlunosAsync();
    }

    private string GetRowClass(string nivelAlerta)
    {
        return nivelAlerta switch
        {
            "Aviso" => "row-aviso",
            "Atencao" => "row-atencao",
            "Critico" => "row-critico",
            _ => ""
        };
    }

    private string GetBadgeClass(string nivelAlerta)
    {
        return nivelAlerta switch
        {
            "Aviso" => "badge-aviso",
            "Atencao" => "badge-atencao",
            "Critico" => "badge-critico",
            _ => "badge-normal"
        };
    }

    private string GetStatusText(string nivelAlerta)
    {
        return nivelAlerta switch
        {
            "Aviso" => "Aviso Escolar (1)",
            "Atencao" => "Atenção (2)",
            "Critico" => "Evasão Crítica (3+)",
            _ => "Estável"
        };
    }
}
