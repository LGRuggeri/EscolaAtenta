{
  "Urls": "http://0.0.0.0:5114",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=escolaatenta_local.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "LogPath": "C:\\EscolaAtenta\\Logs"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://escolaatenta.com.br",
      "https://app.escolaatenta.com.br"
    ]
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Async",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "C:\\EscolaAtenta\\Logs\\api-.log",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 30,
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "RegrasNegocio": {
    "LimiteFaltasParaAlerta": 5,
    "PercentualFaltasParaEvasao": 25
  },
  "Heartbeat": {
    "IntervaloMinutos": 15,
    "EscolaId": "",
    "EndpointNuvem": "",
    "ApiKey": ""
  },
  "EscolaContext": {
    "Id": "00000000-0000-0000-0000-000000000001"
  },
  "CloudSync": {
    "Enabled": false,
    "Endpoint": "",
    "IntervalMinutes": 60
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "EscolaAtenta",
    "Audience": "EscolaAtenta"
  },
  "AllowedHosts": "*"
}